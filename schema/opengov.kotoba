// Opengov clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace opengov {

    entity Project {
        id: string @unique
        name: string
        jurisdiction: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Permit {
        id: string @unique
        projectId: string
        type: string
        number: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Drawing {
        id: string @unique
        projectId: string
        name: string
        revision: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Inspection {
        id: string @unique
        permitId: string
        type: string
        result: string
        inspectedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Asset {
        id: string @unique
        name: string
        type: string
        location: string
        condition: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity ServiceRequest {
        id: string @unique
        citizenId: string
        category: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
